# Immich Server Configuration
IMMICH_URL=http://your-immich-instance:2283
IMMICH_API_KEY=your-api-key-here

# Slideshow Settings
# default is 300 seconds (5 minutes)
REFRESH_DELAY=300

# Night Mode Configuration (24h format)
NIGHT_MODE_START=22
NIGHT_MODE_END=7

# Filtering
EXCLUDED_TAG_IDS=

# Geocoding (Nominatim requires a unique User-Agent to avoid blocks)
# NOTE: You must replace 'your-email-here' with your own email to enable geocoding.
NOMINATIM_USER_AGENT="Pikchurbuk/1.0 (your-email-here@example.com)"

# Regional Settings
TIMEZONE=UTC

# Debugging
ENABLE_LOGGING=false